# java-backend (RAG service)
RAG_SERVER_PORT=8080
RAG_API_PREFIX=/api/v1
BLOG_TITLE=My Personal Blog
RAG_ENABLED=true
RAG_TOP_K=3
RAG_RETRIEVAL_URL=https://your-retrieval-api.example.com/retrieve
RAG_LLM_URL=https://your-llm-api.example.com/generate
RAG_API_KEY=replace_with_real_key

# member-backend (auth/profile service)
MEMBER_SERVER_PORT=8081
MEMBER_API_PREFIX=/api/v1
MEMBER_DB_URL=jdbc:mysql://127.0.0.1:3306/personal_blog_member?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8
MEMBER_DB_USERNAME=root
MEMBER_DB_PASSWORD=123456
MEMBER_DB_DRIVER=com.mysql.cj.jdbc.Driver
MEMBER_AUTH_SESSION_TTL_SECONDS=86400
MEMBER_AUTH_ALLOW_MOCK_VERIFY_CODE=true
MEMBER_AUTH_MOCK_VERIFY_CODE=123456
MEMBER_AUTH_ALLOW_PLAIN_PASSWORD=true
