# unified luoluo-admin application
SERVER_PORT=8080

# datasource
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/personnal-blog?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=1234
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# redis
SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_DATABASE=0
SPRING_DATA_REDIS_TIMEOUT=3s

# rag
API_PREFIX=/api/v1
BLOG_TITLE=My Personal Blog
RAG_ENABLED=true
RAG_EMBEDDING_PROVIDER=demo
RAG_DEMO_EMBEDDING_DIMENSION=64
RAG_API_KEY=replace_with_real_key
RAG_MILVUS_ENABLED=false
RAG_MILVUS_URI=http://127.0.0.1:19530
RAG_MILVUS_TOKEN=
RAG_MILVUS_DATABASE_NAME=
RAG_MILVUS_COLLECTION_NAME=rag_demo_chunks

# member auth
MEMBER_AUTH_SESSION_TTL_SECONDS=86400
MEMBER_AUTH_VERIFY_CODE_TTL_SECONDS=120
MEMBER_AUTH_VERIFY_CODE_SEND_INTERVAL_SECONDS=60
MEMBER_AUTH_IMAGE_CAPTCHA_TTL_SECONDS=120
MEMBER_AUTH_IMAGE_CAPTCHA_LENGTH=4
MEMBER_AUTH_IMAGE_CAPTCHA_ENABLED=false
MEMBER_AUTH_ALLOW_MOCK_VERIFY_CODE=true
MEMBER_AUTH_MOCK_VERIFY_CODE=123456
MEMBER_AUTH_ALLOW_PLAIN_PASSWORD=true

# sms
MEMBER_SMS_ALIYUN_ENABLED=false
MEMBER_SMS_ALIYUN_ACCESS_KEY_ID=
MEMBER_SMS_ALIYUN_ACCESS_KEY_SECRET=
MEMBER_SMS_ALIYUN_REGION_ID=cn-hangzhou
MEMBER_SMS_ALIYUN_ENDPOINT=dysmsapi.aliyuncs.com
MEMBER_SMS_ALIYUN_SIGN_NAME=
MEMBER_SMS_ALIYUN_LOGIN_TEMPLATE_CODE=
MEMBER_SMS_ALIYUN_CODE_PARAM_NAME=code
MEMBER_SMS_ALIYUN_TTL_MINUTES_PARAM_NAME=ttl

# email
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=your_account@example.com
SPRING_MAIL_PASSWORD=replace_with_real_password
SPRING_MAIL_PROTOCOL=smtp
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_SSL_ENABLE=true
SPRING_MAIL_SMTP_CONNECTION_TIMEOUT=5000
SPRING_MAIL_SMTP_TIMEOUT=5000
SPRING_MAIL_SMTP_WRITE_TIMEOUT=5000
MEMBER_EMAIL_LOGIN_SUBJECT=Login verification code
MEMBER_EMAIL_LOGIN_CONTENT_TEMPLATE=Your verification code is %s. It is valid for %d minutes.
